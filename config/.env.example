# =========================================
# Configuración de CumpleBot
# =========================================

# Puerto del servidor web
PORT=3000

# Zona horaria
TZ=Europe/Madrid

# Credenciales de acceso a la interfaz web
AUTH_USER=admin
AUTH_PASS=cumplebot

# Código de país por defecto (sin +)
DEFAULT_COUNTRY_CODE=34

# Ruta de Chromium (se detecta automáticamente si se deja vacío)
CHROMIUM_PATH=
